{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "values": []
  },
  "layer": [
    {
      "params": [
        {"name": "grid", "select": "interval", "bind": "scales"}
      ],
      "transform": [
        {"filter": "datum.emit_detection !== true"}
      ],
      "mark": {
        "type": "line",
        "point": true
      },
      "encoding": {
        "x": {
          "field": "datetime",
          "type": "temporal",
          "title": "Datetime"
        },
        "y": {
          "field": "signal",
          "type": "quantitative",
          "title": "Signal"
        },
        "tooltip": [
          {"field": "datetime", "type": "temporal"},
          {"field": "signal", "type": "quantitative"}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.emit_detection === true"}
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 4],
        "strokeWidth": 2,
        "color": "#e45756"
      },
      "encoding": {
        "x": {
          "field": "datetime",
          "type": "temporal"
        },
        "tooltip": [
          {"field": "datetime", "type": "temporal", "title": "EMIT Detection"}
        ]
      }
    }
  ],
  "background": "transparent"
}
