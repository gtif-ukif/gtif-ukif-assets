{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Simple stacked histograms of Imperviousness (band 1) and UHI intensity (band 2) from a single 2-band COG /statistics response.",
  "background": "transparent",
  "config": {
    "view": { "stroke": null }
  },
  "vconcat": [
    {
      "title": "Imperviousness Distribution (band 1)",
      "data": { "name": "timeseries" },
      "width": "container",
      "height": 200,
      "transform": [
        {
          "calculate": "datum.properties.statistics.asset_b1.histogram[0]",
          "as": "counts"
        },
        {
          "flatten": ["counts"],
          "as": ["count"]
        },
        {
          "window": [{ "op": "row_number", "as": "bin" }]
        }
      ],
      "mark": { "type": "bar", "color": "#555555", "opacity": 0.85 },
      "encoding": {
        "x": {
          "field": "bin",
          "type": "ordinal",
          "title": "Bin",
          "axis": { "labelAngle": 0 }
        },
        "y": {
          "field": "count",
          "type": "quantitative",
          "title": "Pixel count"
        },
        "tooltip": [
          { "field": "bin", "type": "ordinal", "title": "Bin #" },
          { "field": "count", "type": "quantitative", "title": "Pixel count" }
        ]
      }
    },
    {
      "title": "Urban Heat Island Distribution (band 2)",
      "data": { "name": "timeseries" },
      "width": "container",
      "height": 200,
      "transform": [
        {
          "calculate": "datum.properties.statistics.asset_b2.histogram[0]",
          "as": "counts"
        },
        {
          "flatten": ["counts"],
          "as": ["count"]
        },
        {
          "window": [{ "op": "row_number", "as": "bin" }]
        }
      ],
      "mark": { "type": "bar", "color": "#e6a817", "opacity": 0.85 },
      "encoding": {
        "x": {
          "field": "bin",
          "type": "ordinal",
          "title": "Bin",
          "axis": { "labelAngle": 0 }
        },
        "y": {
          "field": "count",
          "type": "quantitative",
          "title": "Pixel count"
        },
        "tooltip": [
          { "field": "bin", "type": "ordinal", "title": "Bin #" },
          { "field": "count", "type": "quantitative", "title": "Pixel count" }
        ]
      }
    }
  ]
}
