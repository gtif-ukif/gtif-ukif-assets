{
    "type": "object",
    "title": "Methane Indicator Parameters",
    "description": "Select AOI by either drawing on the map or entering a bounding box.",
    "format": "grid",
    "properties": {
        "aoi_mode": {
            "type": "string",
            "title": "AOI input method",
            "enum": [
                "draw",
                "text"
            ],
            "default": "draw"
        },
        "aoi": {
            "type": "array",
            "title": "AOI (draw on map)",
            "minItems": 4,
            "maxItems": 4,
            "items": {
                "type": "number"
            },
            "default": [
                -3.67,
                40.23,
                -3.61,
                40.29
            ],
            "format": "bounding-box",
            "options": {
                "autoStartSelection": false,
                "drawtools": {
                    "for": "eox-map#main",
                    "projection": "EPSG:4326"
                }
            }
        },
        "aoi_text": {
            "type": "string",
            "title": "AOI (manual bbox: minLon,minLat,maxLon,maxLat)",
            "default": "",
            "description": "Leave empty to use drawn AOI.",
            "options": {
                "inputAttributes": {
                    "placeholder": "-3.67, 40.23, -3.61, 40.29"
                }
            }
        },
        "toi_start": {
            "type": "string",
            "format": "date",
            "title": "Start Date",
            "default": "2023-01-01"
        },
        "toi_end": {
            "type": "string",
            "format": "date",
            "title": "End Date",
            "default": "2023-01-10"
        },
        "cloud_cover": {
            "type": "number",
            "title": "Max Cloud Cover (%)",
            "minimum": 0,
            "maximum": 100,
            "default": 10
        },
        "limit": {
            "type": "number",
            "title": "Limit (max items)",
            "minimum": 1,
            "maximum": 100,
            "default": 10
        }
    },
    "required": [
        "aoi_mode",
        "toi_start",
        "toi_end",
        "cloud_cover",
        "limit"
    ],
    "additionalProperties": false
}
