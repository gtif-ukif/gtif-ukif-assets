{
    "type": "object",
    "options": { "disable_properties": true },
    "format": "grid-strict",
    "properties": {
        "aoi_mode": {
            "type": "string",
            "title": "AOI input method",
            "enum": [
                "draw",
                "text"
            ],
            "default": "draw",
            "options": {
                "grid_columns": 12
            }
        },
        "aoi": {
            "type": "array",
            "title": "AOI (draw on map)",
            "minItems": 4,
            "maxItems": 4,
            "items": {
                "type": "number"
            },
            "default": [
                -3.67,
                40.23,
                -3.61,
                40.29
            ],
            "format": "bounding-box",
            "options": {
                "autoStartSelection": false,
                "drawtools": {
                    "for": "eox-map#main",
                    "projection": "EPSG:4326"
                },
                "grid_columns": 6
            }
        },
        "aoi_text": {
            "type": "string",
            "title": "AOI bbox (leave empty to use drawn AOI)",
            "default": "",
            "options": {
                "inputAttributes": {
                    "placeholder": "-3.67, 40.23, -3.61, 40.29"
                },
                "grid_columns": 6
            }
        },
        "toi_start": {
            "type": "string",
            "format": "date",
            "title": "Start Date",
            "default": "2023-01-01",
            "options": {
                "grid_columns": 6
            }
        },
        "toi_end": {
            "type": "string",
            "format": "date",
            "title": "End Date",
            "default": "2023-01-10",
            "options": {
                "grid_columns": 6
            }
        },
        "cloud_cover": {
            "type": "number",
            "title": "Max Cloud Cover (%)",
            "minimum": 0,
            "maximum": 100,
            "default": 10,
            "options": {
                "grid_columns": 6
            }
        },
        "limit": {
            "type": "number",
            "title": "Limit (max items)",
            "minimum": 1,
            "maximum": 100,
            "default": 10,
            "options": {
                "grid_columns": 6
            }
        }
    },
    "required": [
        "aoi_mode",
        "toi_start",
        "toi_end",
        "cloud_cover",
        "limit"
    ],
    "additionalProperties": false
}
