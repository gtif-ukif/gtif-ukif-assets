{
  "options": {
    "execute": true,
    "multiQuery": "feature"
  },
  "type": "object",
  "properties": {
    "feature": {
      "type": "geojson",
      "title": "Select one or more BER polygons on map to compare",
      "options": {
        "drawtools": {
          "for": "eox-map#main",
          "layerId": "COMP3",
          "show-list": true,
          "feature-name-key": "ED_NAME",
          "featureStyles": {
            "layer": {
              "fill-color": "rgba(51, 153, 204, 0.45)",
              "stroke-color": "#1c4d6e",
              "stroke-width": 2.5
            },
            "click": {
              "fill-color": "rgba(51, 153, 204, 0.45)",
              "stroke-color": "#1c4d6e",
              "stroke-width": 2.5
            }
          }
        }
      },
      "format": "features"
    }
  }
}
